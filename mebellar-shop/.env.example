# Express backend (mebellar-api)
NEXT_PUBLIC_API_URL=http://localhost:4000

# MongoDB (auth + ma'lumotlar)
MONGODB_URI=mongodb://127.0.0.1:27017/m-mebellar
MONGODB_DB_NAME=m-mebellar

# NextAuth
NEXTAUTH_URL=http://localhost:3001
NEXTAUTH_SECRET=mebellar-dev-secret-ozgartiring

# Do'kon
NEXT_PUBLIC_APP_URL=http://localhost:3001

# Telegram bot orqali saytga o'tish (tunnel yoki production)
# Masalan: https://every-months-kick.loca.lt
TELEGRAM_SHOP_URL=

# Admin panel
NEXT_PUBLIC_ADMIN_URL=http://localhost:3000

# Telegram bot (OTP autentifikatsiyasi)
# Bot yaratish: @BotFather → /newbot
# Bot tokeni mavjud bo'lmasa — dev rejimida OTP kod javobda qaytariladi.
TELEGRAM_BOT_USERNAME=mebeluz_bot
TELEGRAM_BOT_TOKEN=

# DeepL API (rus tiliga real-time tarjima)
# Free key: https://www.deepl.com/pro-api — oxiri :fx bo'ladi
DEEPL_API_KEY=
# Webhook ulash (faqat HTTPS bo'lgan domen uchun):
#   curl "https://api.telegram.org/bot<TOKEN>/setWebhook?url=https://YOUR_DOMAIN/api/telegram/webhook"

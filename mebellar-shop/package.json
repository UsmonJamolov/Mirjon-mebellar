{
  "name": "mebellar-shop",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3001",
    "dev:clean": "node --input-type=module -e \"import fs from 'fs'; fs.rmSync('.next',{recursive:true,force:true});\" && next dev -p 3001",
    "build": "next build",
    "start": "next start -p 3001",
    "lint": "next lint",
    "telegram:poll": "node ../scripts/telegram-poll-loop.mjs",
    "telegram:webhook": "node --input-type=module -e \"fetch('http://localhost:3001/api/telegram/set-webhook',{method:'POST'}).then(r=>r.json()).then(console.log).catch(console.error)\""
  },
  "dependencies": {
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "bcryptjs": "^3.0.3",
    "clsx": "^2.1.1",
    "framer-motion": "^12.40.0",
    "gsap": "^3.15.0",
    "lenis": "^1.3.23",
    "lucide-react": "^0.511.0",
    "mongoose": "^9.6.2",
    "next": "^15.3.3",
    "next-auth": "^4.24.11",
    "next-intl": "^4.12.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "three": "^0.184.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@tailwindcss/postcss": "^4.1.7",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.15.21",
    "@types/react": "^19.1.4",
    "@types/react-dom": "^19.1.5",
    "@types/three": "^0.184.1",
    "eslint": "^9.27.0",
    "eslint-config-next": "^15.3.3",
    "postcss": "^8.5.3",
    "tailwindcss": "^4.1.7",
    "typescript": "^5.8.3"
  }
}
